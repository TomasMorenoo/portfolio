---
import Layout from '../layouts/Layout.astro';
import AdminNavbar from '../components/AdminNavbar.astro';
import db from '../lib/db.js';
import fs from 'node:fs';
import path from 'node:path';
import { createHash } from 'node:crypto';
import { loginAttempts } from '../lib/ratelimit.js';

const MAX_INTENTOS = 5;
const BLOQUEO_MS   = 15 * 60 * 1000; // 15 minutos

let mensaje     = "";
let loginError  = "";
let autorizado  = false;

const passwordSistema = import.meta.env.ADMIN_PASSWORD;
// La cookie guarda un hash, nunca la contraseña en texto plano
const sessionToken = createHash('sha256').update(passwordSistema + '-mobatai-salt').digest('hex');
const cookieToken  = Astro.cookies.get('admin_auth')?.value;

if (cookieToken === sessionToken) autorizado = true;

// Helper para subir archivos
async function subirArchivo(file, nombre) {
  const buffer    = Buffer.from(await file.arrayBuffer());
  const uploadDir = path.join(process.cwd(), 'public', 'uploads');
  if (!fs.existsSync(uploadDir)) fs.mkdirSync(uploadDir, { recursive: true });
  fs.writeFileSync(path.join(uploadDir, nombre), buffer);
  return `/uploads/${nombre}`;
}

if (Astro.request.method === 'POST') {
  const data   = await Astro.request.formData();
  const accion = data.get('accion');

  // ── LOGIN con rate limiting ──────────────────────────────────────────────
  if (accion === 'login') {
    const ip      = Astro.request.headers.get('x-forwarded-for')?.split(',')[0].trim() || 'unknown';
    const intento = loginAttempts.get(ip) || { count: 0, blockedUntil: 0 };

    if (intento.blockedUntil > Date.now()) {
      const mins = Math.ceil((intento.blockedUntil - Date.now()) / 60000);
      loginError = `Demasiados intentos. Esperá ${mins} min.`;
    } else if (data.get('password') === passwordSistema) {
      intento.count = 0;
      loginAttempts.set(ip, intento);
      Astro.cookies.set('admin_auth', sessionToken, { path: '/', httpOnly: true, sameSite: 'strict' });
      return Astro.redirect('/admin');
    } else {
      intento.count++;
      if (intento.count >= MAX_INTENTOS) intento.blockedUntil = Date.now() + BLOQUEO_MS;
      loginAttempts.set(ip, intento);
      loginError = intento.count >= MAX_INTENTOS
        ? `Bloqueado 15 minutos.`
        : `Contraseña incorrecta (${intento.count}/${MAX_INTENTOS}).`;
    }
  }

  if (autorizado) {
    // ── ACTUALIZAR PERFIL ────────────────────────────────────────────────
    if (accion === 'actualizar_perfil') {
      const cvFile  = data.get('cv_file');
      let   cvUrl   = db.prepare("SELECT valor FROM configuracion WHERE clave='cv_url'").get()?.valor || '';
      if (cvFile?.size > 0) cvUrl = await subirArchivo(cvFile, `cv-mobatai.pdf`) + `?v=${Date.now()}`;

      const avatarFile = data.get('avatar_file');
      let   avatarUrl  = db.prepare("SELECT valor FROM configuracion WHERE clave='avatar_url'").get()?.valor || '';
      if (avatarFile?.size > 0) {
        const ext = avatarFile.name.split('.').pop();
        avatarUrl = await subirArchivo(avatarFile, `avatar-${Date.now()}.${ext}`);
      }

      const safeUpdate = (clave, valor) => {
        const r = db.prepare('UPDATE configuracion SET valor=? WHERE clave=?').run(valor, clave);
        if (r.changes === 0) db.prepare('INSERT INTO configuracion (clave,valor) VALUES (?,?)').run(clave, valor);
      };

      ['nombre','email','bio','whatsapp_number','whatsapp_msg',
       'sobre_mi_id','sobre_mi_base','sobre_mi_status','sobre_mi_texto','radar_techs',
       'github_url','linkedin_url'
      ].forEach(k => safeUpdate(k, data.get(k) ?? ''));

      safeUpdate('cv_url',     cvUrl);
      safeUpdate('avatar_url', avatarUrl);
      safeUpdate('disponible', data.get('disponible') ? 'true' : 'false');
      mensaje = "✅ Sistema Sincronizado";
    }

    // ── GUARDAR PROYECTO ─────────────────────────────────────────────────
    if (accion === 'guardar_proyecto') {
      const imgFile = data.get('proyecto_img');
      let imagenUrl = '';
      if (imgFile?.size > 0) imagenUrl = await subirArchivo(imgFile, `p-${Date.now()}.webp`);

      const maxOrden = db.prepare('SELECT COALESCE(MAX(orden),0) AS m FROM proyectos').get().m;
      db.prepare(`INSERT INTO proyectos
        (titulo,descripcion,tags,tipo,imagen_url,demo_url,github_url,demo_usuario,demo_password,estado,orden)
        VALUES (?,?,?,?,?,?,?,?,?,?,?)`).run(
          data.get('titulo'), data.get('descripcion'), data.get('tags'), data.get('tipo'),
          imagenUrl, data.get('demo_url'), data.get('github_url'),
          data.get('demo_usuario') || null, data.get('demo_password') || null,
          data.get('estado') || 'Terminado', maxOrden + 1
      );
      mensaje = "🚀 Proyecto Desplegado";
    }

    // ── BORRAR PROYECTO ──────────────────────────────────────────────────
    if (accion === 'borrar_proyecto') {
      db.prepare('DELETE FROM proyectos WHERE id=?').run(data.get('id'));
      mensaje = "🗑️ Eliminado";
    }

    // ── EDITAR PROYECTO ──────────────────────────────────────────────────
    if (accion === 'editar_proyecto') {
      const id      = data.get('id');
      const imgFile = data.get('proyecto_img');
      let imagenUrl = data.get('imagen_url_actual') || '';
      if (imgFile?.size > 0) imagenUrl = await subirArchivo(imgFile, `p-${Date.now()}.webp`);

      db.prepare(`UPDATE proyectos
        SET titulo=?,descripcion=?,tags=?,tipo=?,imagen_url=?,demo_url=?,github_url=?,
            demo_usuario=?,demo_password=?,estado=?
        WHERE id=?`).run(
          data.get('titulo'), data.get('descripcion'), data.get('tags'), data.get('tipo'),
          imagenUrl, data.get('demo_url'), data.get('github_url'),
          data.get('demo_usuario') || null, data.get('demo_password') || null,
          data.get('estado') || 'Terminado', id
      );
      mensaje = "✏️ Proyecto Actualizado";
    }

    // ── REORDENAR PROYECTO ───────────────────────────────────────────────
    if (accion === 'mover_proyecto') {
      const id        = parseInt(data.get('id'));
      const dir       = data.get('direccion'); // 'arriba' | 'abajo'
      const proyecto  = db.prepare('SELECT * FROM proyectos WHERE id=?').get(id);
      let   adyacente;

      if (dir === 'arriba') {
        adyacente = db.prepare('SELECT * FROM proyectos WHERE orden > ? ORDER BY orden ASC LIMIT 1').get(proyecto.orden);
      } else {
        adyacente = db.prepare('SELECT * FROM proyectos WHERE orden < ? ORDER BY orden DESC LIMIT 1').get(proyecto.orden);
      }

      if (adyacente) {
        db.prepare('UPDATE proyectos SET orden=? WHERE id=?').run(adyacente.orden, id);
        db.prepare('UPDATE proyectos SET orden=? WHERE id=?').run(proyecto.orden, adyacente.id);
        mensaje = "↕️ Reordenado";
      }
    }
  }
}

const configArr  = db.prepare('SELECT * FROM configuracion').all();
const config     = Object.fromEntries(configArr.map(i => [i.clave, i.valor]));
const proyectosDB = db.prepare('SELECT * FROM proyectos ORDER BY orden DESC').all();
---

<Layout title="Admin Mobatai">
  {autorizado ? <AdminNavbar /> : null}

  <main class="pt-24 px-6 max-w-5xl mx-auto text-white pb-32">
    {!autorizado ? (
      <div class="max-w-md mx-auto bg-slate-900 p-10 rounded-[2rem] border border-white/5 mt-20 text-center">
         <h1 class="text-2xl font-black italic mb-8 uppercase">Mobatai <span class="text-blue-500">Root</span></h1>
         <form method="POST">
           <input type="hidden" name="accion" value="login" />
           <input type="password" name="password" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-center mb-4 outline-none" placeholder="KEY" autofocus />
           {loginError && (
             <p class="text-[10px] text-red-400 font-bold uppercase tracking-widest mb-4">{loginError}</p>
           )}
           <button class="w-full bg-blue-600 py-4 rounded-xl font-black uppercase text-[10px] tracking-widest">Entrar</button>
         </form>
      </div>
    ) : (
      
      <div class="flex flex-col gap-16">
        
        <section class="bg-slate-900/80 p-8 md:p-10 rounded-[2.5rem] border border-white/10 backdrop-blur-xl">
           <h2 class="text-xs font-black uppercase tracking-widest text-emerald-400 mb-8 border-b border-white/5 pb-4">1. Ajustes Globales del Operador</h2>
           
           <form method="POST" enctype="multipart/form-data" class="space-y-8">
              <input type="hidden" name="accion" value="actualizar_perfil" />
              
              <label class="inline-flex items-center gap-3 bg-slate-800/30 p-3 rounded-xl border border-white/5 cursor-pointer w-max">
                  <input type="checkbox" name="disponible" checked={config.disponible === 'true'} class="w-4 h-4 accent-emerald-500" />
                  <span class="text-[10px] font-bold uppercase tracking-tighter">Disponible para trabajar</span>
              </label>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                 <div class="space-y-2">
                    <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Nombre Principal</p>
                    <input name="nombre" value={config.nombre} class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm" />
                 </div>
                 <div class="space-y-2">
                    <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Número WhatsApp</p>
                    <input name="whatsapp_number" value={config.whatsapp_number} placeholder="Ej: 54911..." class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm" />
                 </div>

                 <div class="space-y-2">
                    <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Biografía Corta (Hero)</p>
                    <textarea name="bio" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm h-24 resize-none">{config.bio}</textarea>
                 </div>
                 <div class="space-y-2">
                    <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Mensaje Prearmado WhatsApp</p>
                    <textarea name="whatsapp_msg" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm h-24 resize-none">{config.whatsapp_msg}</textarea>
                 </div>

                 <div class="space-y-2">
                    <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Radar Técnico (separado por coma)</p>
                    <input name="radar_techs" value={config.radar_techs} class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm" />
                 </div>
                 <div class="space-y-2">
                    <p class="text-[9px] font-black uppercase text-slate-500 ml-2">GitHub URL</p>
                    <input name="github_url" value={config.github_url} placeholder="https://github.com/tu-usuario" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm" />
                 </div>
                 <div class="space-y-2">
                    <p class="text-[9px] font-black uppercase text-slate-500 ml-2">LinkedIn URL</p>
                    <input name="linkedin_url" value={config.linkedin_url} placeholder="https://linkedin.com/in/tu-perfil" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm" />
                 </div>
                 <div class="space-y-2">
                    <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Currículum PDF</p>
                    <div class="w-full bg-slate-800 p-3 rounded-xl border border-white/5 flex items-center justify-between h-[54px]">
                       <input type="file" name="cv_file" accept=".pdf" class="text-[10px] text-slate-400" />
                       {config.cv_url && <a href={config.cv_url} target="_blank" class="text-[9px] text-blue-400 underline uppercase font-bold">Ver PDF</a>}
                    </div>
                 </div>
              </div>

              <div class="pt-8 mt-4 border-t border-white/5">
                  <p class="text-[11px] font-black uppercase text-purple-400 mb-6">Datos Personales (Sección Sobre Mí)</p>
                  
                  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                      
                      <div class="space-y-2">
                          <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Foto / Avatar</p>
                          <div class="w-full bg-slate-800 p-2 rounded-xl border border-white/5 flex items-center gap-3 h-[54px]">
                             {config.avatar_url ? (
                               <img src={config.avatar_url} class="w-8 h-8 rounded-full object-cover border border-white/10 shrink-0" />
                             ) : (
                               <div class="w-8 h-8 rounded-full bg-slate-900 border border-white/10 shrink-0"></div>
                             )}
                             <input type="file" name="avatar_file" accept="image/*" class="text-[9px] text-slate-400 w-full" />
                          </div>
                      </div>

                      <div class="space-y-2">
                          <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Ubicación</p>
                          <input name="sobre_mi_id" value={config.sobre_mi_id} placeholder="Ej: Hudson, Buenos Aires" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm" />
                      </div>

                      <div class="space-y-2">
                          <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Fuera del teclado</p>
                          <input name="sobre_mi_base" value={config.sobre_mi_base} placeholder="Ej: Fotografía, Bowling" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm" />
                      </div>

                      <div class="space-y-2 md:col-span-3">
                          <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Idiomas</p>
                          <input name="sobre_mi_status" value={config.sobre_mi_status} placeholder="Ej: Español nativo, Inglés técnico" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm" />
                      </div>

                      <div class="space-y-2 md:col-span-3">
                          <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Texto Descriptivo</p>
                          <textarea name="sobre_mi_texto" placeholder="Usá {{EDAD}} en el texto para calcular tu edad automática." class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm h-40 resize-none">{config.sobre_mi_texto}</textarea>
                      </div>
                  </div>
              </div>

              <button class="w-full bg-emerald-600 py-5 rounded-xl font-black uppercase text-[11px] tracking-widest transition-all hover:bg-emerald-500 shadow-xl shadow-emerald-500/10 mt-4">Sincronizar Todos los Datos</button>
           </form>
        </section>

        <section class="bg-slate-900 p-8 md:p-10 rounded-[2.5rem] border border-white/10">
          <h2 class="text-xs font-black uppercase tracking-widest text-blue-500 mb-8 border-b border-white/5 pb-4">2. Desplegar Nuevo Proyecto</h2>
          <form method="POST" enctype="multipart/form-data" class="space-y-6">
            <input type="hidden" name="accion" value="guardar_proyecto" />
            
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
              <div class="md:col-span-2 space-y-2">
                  <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Título del Proyecto</p>
                  <input name="titulo" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm" required />
              </div>
              <div class="space-y-2">
                  <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Tipo</p>
                  <select name="tipo" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-[11px] font-black uppercase outline-none text-white h-[54px]">
                     <option value="SOFTWARE">SOFTWARE</option>
                     <option value="HARDWARE">HARDWARE</option>
                  </select>
              </div>
              <div class="space-y-2">
                  <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Estado</p>
                  <select name="estado" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-[11px] font-black uppercase outline-none text-white h-[54px]">
                     <option value="Terminado">Terminado</option>
                     <option value="En desarrollo">En desarrollo</option>
                     <option value="Archivado">Archivado</option>
                  </select>
              </div>
            </div>

            <div class="space-y-2">
                <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Descripción Técnica</p>
                <textarea name="descripcion" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 h-24 text-sm resize-none outline-none"></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
               <div class="md:col-span-2 space-y-2">
                   <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Tags (Separados por coma)</p>
                   <input name="tags" placeholder="Ej: Python, Docker, Astro" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm outline-none" />
               </div>
               <div class="space-y-2">
                   <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Imagen de Portada</p>
                   <div class="w-full bg-slate-800 p-3 rounded-xl border border-white/5 flex items-center h-[54px]">
                       <input type="file" name="proyecto_img" accept="image/*" class="text-[10px] text-slate-400 w-full" />
                   </div>
               </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
               <div class="space-y-2">
                   <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Link de Demostración (Demo)</p>
                   <input name="demo_url" placeholder="https://tudemo.com" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm" />
               </div>
               <div class="space-y-2">
                   <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Link de GitHub (Código)</p>
                   <input name="github_url" placeholder="https://github.com/tu-repo" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm" />
               </div>
            </div>

            <div class="border-t border-white/5 pt-6">
              <p class="text-[9px] font-black uppercase text-amber-400/80 mb-4 ml-2">Credenciales de Acceso Demo (opcional)</p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Usuario Demo</p>
                  <input name="demo_usuario" placeholder="demo" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm outline-none" />
                </div>
                <div class="space-y-2">
                  <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Contraseña Demo</p>
                  <input name="demo_password" placeholder="demo" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm outline-none" />
                </div>
              </div>
              <p class="text-[8px] text-slate-600 mt-2 ml-2">Si completás estos campos, se muestran en la card del proyecto para que los visitantes puedan probar la demo.</p>
            </div>

            <button class="w-full bg-blue-600 py-5 rounded-xl font-black uppercase tracking-widest text-[11px] hover:bg-blue-500 transition-all shadow-xl shadow-blue-500/10">Ejecutar Despliegue en DB</button>
          </form>
        </section>

        <section>
          <h2 class="text-xs font-black uppercase tracking-widest text-slate-400 mb-6 px-2">3. Proyectos en Producción ({proyectosDB.length})</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
             {proyectosDB.map(p => (
               <div class="flex flex-col bg-slate-900/40 rounded-[2rem] border border-white/5 overflow-hidden group hover:border-blue-500/30 transition-colors">
                 
                 <div class="h-40 bg-slate-800 relative overflow-hidden">
                    <img
                      src={p.imagen_url
                        ? p.imagen_url
                        : p.demo_url
                          ? `https://s.wordpress.com/mshots/v1/${encodeURIComponent(p.demo_url)}?w=800&h=450`
                          : '/placeholder.webp'}
                      class="w-full h-full object-cover opacity-70 group-hover:opacity-100 transition-opacity"
                      loading="lazy"
                    />
                    <div class="absolute top-3 left-3 flex gap-1.5 flex-wrap">
                      <span class="px-2 py-1 bg-black/80 backdrop-blur-md border border-white/10 rounded text-[9px] font-black uppercase text-blue-400">{p.tipo}</span>
                      <span class={`px-2 py-1 backdrop-blur-md border rounded text-[8px] font-black uppercase ${
                        p.estado === 'En desarrollo' ? 'bg-amber-500/20 border-amber-500/30 text-amber-400'
                        : p.estado === 'Archivado'   ? 'bg-slate-800/80 border-white/10 text-slate-500'
                        : 'bg-emerald-500/10 border-emerald-500/20 text-emerald-400'
                      }`}>{p.estado || 'Terminado'}</span>
                    </div>
                    {(p.visitas_demo > 0 || p.visitas_codigo > 0) && (
                      <div class="absolute bottom-2 right-2 flex gap-1">
                        {p.visitas_demo > 0 && <span class="text-[8px] font-bold bg-blue-500/20 border border-blue-500/30 text-blue-400 px-1.5 py-0.5 rounded">👁 {p.visitas_demo}</span>}
                        {p.visitas_codigo > 0 && <span class="text-[8px] font-bold bg-white/10 border border-white/10 text-slate-400 px-1.5 py-0.5 rounded">💻 {p.visitas_codigo}</span>}
                      </div>
                    )}
                 </div>

                 <div class="p-5 flex flex-col flex-grow">
                    <h3 class="text-base font-bold uppercase truncate text-white mb-1 italic tracking-tighter">{p.titulo}</h3>
                    <p class="text-xs text-slate-500 line-clamp-2 mb-4 flex-grow leading-relaxed">{p.descripcion}</p>

                    <div class="mt-auto pt-3 border-t border-white/5 grid grid-cols-4 gap-1.5">
                      <!-- ↑ sube en la lista (mayor orden) -->
                      <form method="POST">
                        <input type="hidden" name="accion" value="mover_proyecto" />
                        <input type="hidden" name="id" value={p.id} />
                        <input type="hidden" name="direccion" value="arriba" />
                        <button title="Subir" class="w-full text-slate-400 hover:text-white text-sm py-2.5 rounded-xl bg-white/5 hover:bg-white/10 transition-all">↑</button>
                      </form>
                      <!-- ↓ baja en la lista (menor orden) -->
                      <form method="POST">
                        <input type="hidden" name="accion" value="mover_proyecto" />
                        <input type="hidden" name="id" value={p.id} />
                        <input type="hidden" name="direccion" value="abajo" />
                        <button title="Bajar" class="w-full text-slate-400 hover:text-white text-sm py-2.5 rounded-xl bg-white/5 hover:bg-white/10 transition-all">↓</button>
                      </form>
                      <!-- Editar -->
                      <button
                        class="edit-btn text-[9px] font-black text-blue-400 uppercase py-2.5 rounded-xl bg-blue-500/5 hover:bg-blue-500 hover:text-white transition-all"
                        data-id={p.id}
                        data-titulo={p.titulo}
                        data-descripcion={p.descripcion}
                        data-tags={p.tags}
                        data-tipo={p.tipo}
                        data-estado={p.estado || 'Terminado'}
                        data-imagen_url={p.imagen_url || ''}
                        data-demo_url={p.demo_url || ''}
                        data-github_url={p.github_url || ''}
                        data-demo_usuario={p.demo_usuario || ''}
                        data-demo_password={p.demo_password || ''}
                      >✏️</button>
                      <!-- Eliminar -->
                      <form method="POST">
                        <input type="hidden" name="accion" value="borrar_proyecto" />
                        <input type="hidden" name="id" value={p.id} />
                        <button
                          onclick="return confirm('¿Eliminar este proyecto? Esta acción no se puede deshacer.')"
                          class="w-full text-[9px] font-black text-red-400 py-2.5 rounded-xl bg-red-500/5 hover:bg-red-500 hover:text-white transition-all"
                        >🗑️</button>
                      </form>
                    </div>
                 </div>
               </div>
             ))}
             
             {proyectosDB.length === 0 && (
               <div class="col-span-full text-center py-20 border border-dashed border-white/10 rounded-[2.5rem] bg-slate-900/10">
                  <p class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-600">No hay proyectos cargados en la base de datos</p>
               </div>
             )}
          </div>
        </section>

      </div>
    )}
  </main>
  
  {mensaje ? (
    <div class="fixed bottom-10 right-10 bg-white text-black px-8 py-4 rounded-2xl font-black z-50 animate-bounce text-[10px] uppercase shadow-2xl">
      {mensaje}
    </div>
  ) : null}

  <!-- Modal de edición -->
  <div id="edit-modal" class="fixed inset-0 z-[200] flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200">
    <div class="bg-slate-900 border border-white/10 rounded-[2.5rem] w-full max-w-2xl max-h-[90vh] overflow-y-auto p-8 shadow-2xl">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-sm font-black uppercase tracking-widest text-blue-400">✏️ Editar Proyecto</h2>
        <button id="close-modal" class="w-8 h-8 flex items-center justify-center rounded-xl bg-white/5 hover:bg-white/10 text-slate-400 hover:text-white transition-all text-lg">✕</button>
      </div>

      <form method="POST" enctype="multipart/form-data" class="space-y-5">
        <input type="hidden" name="accion" value="editar_proyecto" />
        <input type="hidden" name="id" id="edit-id" />
        <input type="hidden" name="imagen_url_actual" id="edit-imagen_url_actual" />

        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div class="md:col-span-2 space-y-2">
            <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Título</p>
            <input id="edit-titulo" name="titulo" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm outline-none" required />
          </div>
          <div class="space-y-2">
            <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Tipo</p>
            <select id="edit-tipo" name="tipo" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-[11px] font-black uppercase outline-none text-white h-[54px]">
              <option value="SOFTWARE">SOFTWARE</option>
              <option value="HARDWARE">HARDWARE</option>
            </select>
          </div>
          <div class="space-y-2">
            <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Estado</p>
            <select id="edit-estado" name="estado" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-[11px] font-black uppercase outline-none text-white h-[54px]">
              <option value="Terminado">Terminado</option>
              <option value="En desarrollo">En desarrollo</option>
              <option value="Archivado">Archivado</option>
            </select>
          </div>
        </div>

        <div class="space-y-2">
          <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Descripción</p>
          <textarea id="edit-descripcion" name="descripcion" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 h-24 text-sm resize-none outline-none"></textarea>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="md:col-span-2 space-y-2">
            <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Tags (separados por coma)</p>
            <input id="edit-tags" name="tags" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm outline-none" />
          </div>
          <div class="space-y-2">
            <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Nueva imagen (opcional)</p>
            <div class="w-full bg-slate-800 p-3 rounded-xl border border-white/5 flex items-center h-[54px]">
              <input type="file" name="proyecto_img" accept="image/*" class="text-[10px] text-slate-400 w-full" />
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="space-y-2">
            <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Link Demo</p>
            <input id="edit-demo_url" name="demo_url" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm outline-none" />
          </div>
          <div class="space-y-2">
            <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Link GitHub</p>
            <input id="edit-github_url" name="github_url" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm outline-none" />
          </div>
        </div>

        <div class="border-t border-white/5 pt-4">
          <p class="text-[9px] font-black uppercase text-amber-400/80 mb-3 ml-2">Credenciales Demo (opcional)</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-2">
              <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Usuario Demo</p>
              <input id="edit-demo_usuario" name="demo_usuario" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm outline-none" />
            </div>
            <div class="space-y-2">
              <p class="text-[9px] font-black uppercase text-slate-500 ml-2">Contraseña Demo</p>
              <input id="edit-demo_password" name="demo_password" class="w-full bg-slate-800 p-4 rounded-xl border border-white/5 text-sm outline-none" />
            </div>
          </div>
        </div>

        <button class="w-full bg-blue-600 hover:bg-blue-500 py-5 rounded-xl font-black uppercase tracking-widest text-[11px] transition-all shadow-xl shadow-blue-500/10 mt-2">
          Guardar Cambios
        </button>
      </form>
    </div>
  </div>
</Layout>

<script>
  const modal     = document.getElementById('edit-modal');
  const closeBtn  = document.getElementById('close-modal');

  document.querySelectorAll('.edit-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const d = btn.dataset;
      document.getElementById('edit-id').value                = d.id;
      document.getElementById('edit-titulo').value            = d.titulo;
      document.getElementById('edit-descripcion').value       = d.descripcion;
      document.getElementById('edit-tags').value              = d.tags;
      document.getElementById('edit-demo_url').value          = d.demo_url;
      document.getElementById('edit-github_url').value        = d.github_url;
      document.getElementById('edit-demo_usuario').value      = d.demo_usuario;
      document.getElementById('edit-demo_password').value     = d.demo_password;
      document.getElementById('edit-imagen_url_actual').value = d.imagen_url;

      for (let opt of document.getElementById('edit-tipo').options)
        opt.selected = opt.value === d.tipo.toUpperCase();

      for (let opt of document.getElementById('edit-estado').options)
        opt.selected = opt.value === d.estado;

      modal.classList.remove('opacity-0', 'pointer-events-none');
      modal.classList.add('opacity-100');
    });
  });

  function closeModal() {
    modal.classList.add('opacity-0', 'pointer-events-none');
    modal.classList.remove('opacity-100');
  }

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
</script>